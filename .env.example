N8N_ENCRYPTION_KEY=replace_with_a_long_random_string

# สมัครฟรีที่ https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=replace_with_your_ngrok_authtoken
# สร้าง Static Domain ฟรี 1 โดเมนได้ที่ https://dashboard.ngrok.com/domains
NGROK_DOMAIN=replace_with_your_ngrok_static_domain

# ค่านี้ไม่ได้ถูกอ่านโดย Mosquitto โดยตรง ใช้เป็นค่าที่จดจำไว้เท่านั้น
# ต้องสร้าง mosquitto/config/passwordfile จริงด้วยคำสั่ง mosquitto_passwd
# ตามขั้นตอนใน README หัวข้อ "ความปลอดภัยของ MQTT Broker"
MQTT_USERNAME=replace_with_mqtt_username
MQTT_PASSWORD=replace_with_mqtt_password
